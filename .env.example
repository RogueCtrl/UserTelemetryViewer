# Telemetry Game Server Configuration

# The port the Express + Socket.io server will listen on
PORT=3001

# Production Auth for /api/events:
# If POSTHOG_WEBHOOK_SECRET is set, the /api/events endpoint will verify the
# X-Posthog-Signature header using HMAC-SHA256.
# Format: sha256=<hmac-hex>
# POSTHOG_WEBHOOK_SECRET=your_secret_here

# API Key fallback:
# If TELEMETRY_API_KEY is set, the /api/events endpoint will also accept
# 'Authorization: Bearer <key>' header. Named TELEMETRY_API_KEY (not
# POSTHOG_API_KEY) to avoid clashing with PostHog's own client SDK env var.
# TELEMETRY_API_KEY=your_api_key_here

# OpenTelemetry Auth (optional):
# If set, the OTLP endpoint (/api/otlp/v1/traces) requires
# 'Authorization: Bearer <token>'
# OTEL_BEARER_TOKEN=your_secret_token_here
